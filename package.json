{
  "name": "menufy",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "next:dev": "next dev --webpack",
    "dev": "concurrently \"npm run next:dev\" \"node bull-server/dashboard.js\"",
    "start:worker": "node ./src/lib/bullmq/worker/menu-parser.js",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:next": "next build && node scripts/prepare-standalone.js",
    "build:electron:mac": "npm run build:next && electron-builder --mac --arm64 --x64",
    "build:electron:win": "npm run build:next && electron-builder --win",
    "build:electron:all": "npm run build:next && electron-builder --mac --arm64 --x64 --win"
  },
  "build": {
    "appId": "in.magicscale.menufy",
    "productName": "Menufy",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "bull-server/**/*",
      "src/lib/bullmq/**/*",
      ".env"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    }
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.927.0",
    "@base-ui/react": "^1.6.0",
    "@bull-board/api": "^7.2.1",
    "@bull-board/express": "^7.2.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^1.29.0",
    "@huggingface/transformers": "^4.2.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.1",
    "@reduxjs/toolkit": "^2.10.1",
    "@tabler/icons-react": "^3.35.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "axios": "^1.13.2",
    "bullmq": "^5.78.0",
    "canvas": "^3.2.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "file-type": "^22.0.1",
    "form-data": "^4.0.5",
    "formik": "^2.4.8",
    "framer-motion": "^12.23.24",
    "get-port": "^5.1.1",
    "ioredis": "^5.11.1",
    "lodash.merge": "^4.6.2",
    "lucide-react": "^0.553.0",
    "mongodb": "^7.0.0",
    "mongoose": "^8.19.3",
    "motion": "^12.23.24",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.10",
    "partial-json-parser": "^1.2.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^6.1.200",
    "postcss": "^8.5.15",
    "radix-ui": "^1.6.0",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "react-dropzone": "^14.4.1",
    "react-redux": "^9.2.0",
    "shadcn": "^4.12.0",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.10.38",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "wait-on": "^9.0.10"
  }
}
