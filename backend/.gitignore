.env
.env.*
!.env.example

# ─── Distribution / Packaging ──────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ─── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ─── Type Checking ─────────────────────────────────────────────
