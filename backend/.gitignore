# ─── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# ─── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

